@using System.Security.Claims
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - RentaKey</title>
    <link rel="icon" href="~/images/logo.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-rentakey shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="RentaKey" height="36" />
                <span class="fw-bold">RentaKey</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto ms-3">
                    <li class="nav-item"><a class="nav-link" asp-controller="Properties" asp-action="Index">Propiedades</a></li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Reservations" asp-action="Index">Mis Reservas</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Wishlist" asp-action="Index">Favoritos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Kyc" asp-action="Upload">Verificación KYC</a></li>
                        @if (User.IsInRole("Owner") || User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index"><i class="fa-solid fa-gauge-high me-1"></i>Panel Propietario</a></li>
                        }
                    }
                </ul>
                <ul class="navbar-nav ms-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fa-solid fa-circle-user me-1"></i>@User.GetFirstName()
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><span class="dropdown-item-text small text-muted">Rol: @User.GetRole()</span></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item">Cerrar sesión</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Iniciar sesión</a></li>
                        <li class="nav-item"><a class="btn btn-accent ms-2 text-white" asp-controller="Account" asp-action="Register">Registrarse</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @if (TempData["Success"] is string success)
        {
            <div class="container mt-3"><div class="alert alert-success alert-dismissible fade show">@success
                <button class="btn-close" data-bs-dismiss="alert"></button></div></div>
        }
        @if (TempData["Error"] is string err)
        {
            <div class="container mt-3"><div class="alert alert-danger alert-dismissible fade show">@err
                <button class="btn-close" data-bs-dismiss="alert"></button></div></div>
        }
        @RenderBody()
    </main>

    <footer class="footer-rentakey mt-5 py-4">
        <div class="container d-flex flex-wrap justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <img src="~/images/logo.png" height="28" alt="RentaKey" />
                <span class="small">© @DateTime.Now.Year RentaKey · Propiedades y verificación con IA</span>
            </div>
            <div class="small">
                <a href="#" class="me-3">Términos</a>
                <a href="#" class="me-3">Privacidad</a>
                <a href="#">Soporte</a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
