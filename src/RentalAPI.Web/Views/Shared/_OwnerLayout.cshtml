@{
    Layout = "_Layout";
}
<div class="container-fluid">
    <div class="row">
        <aside class="col-md-3 col-lg-2 sidebar-owner p-3">
            <nav class="nav flex-column gap-1">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <i class="fa-solid fa-gauge-high me-2"></i>Dashboard
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "OwnerProperties" ? "active" : "")"
                   asp-controller="OwnerProperties" asp-action="Index">
                    <i class="fa-solid fa-house me-2"></i>Mis Propiedades
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")"
                       asp-controller="Reports" asp-action="Index">
                        <i class="fa-solid fa-file-excel me-2"></i>Reportes
                    </a>
                }
                <hr />
                <a class="nav-link" asp-controller="Properties" asp-action="Index">
                    <i class="fa-solid fa-arrow-left me-2"></i>Volver al sitio
                </a>
            </nav>
        </aside>
        <section class="col-md-9 col-lg-10 p-4">
            @RenderBody()
        </section>
    </div>
</div>
@await RenderSectionAsync("Scripts", required: false)
