@model List<PropertyDto>
@{
    ViewData["Title"] = "Mis Propiedades";
    Layout = "_OwnerLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Mis Propiedades</h2>
    <a class="btn btn-primary text-white" asp-controller="OwnerProperties" asp-action="Create">
        <i class="fa-solid fa-plus me-1"></i>Nueva propiedad
    </a>
</div>

@if (!Model.Any())
{
    <p class="text-muted">Aún no has publicado propiedades.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover bg-white align-middle card-rentakey">
            <thead>
                <tr><th>Título</th><th>Ciudad</th><th>Precio/noche</th><th>Capacidad</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Title</td>
                        <td>@p.City</td>
                        <td>$@p.PricePerNight.ToString("N0")</td>
                        <td>@p.MaxGuests huéspedes · @p.Bedrooms hab.</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="OwnerProperties" asp-action="Edit" asp-route-id="@p.Id">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <form asp-controller="OwnerProperties" asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar esta propiedad?');">
                                <button class="btn btn-sm btn-outline-danger" type="submit"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
