@model PropertyFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
@if (Model.Id is not null)
{
    <input type="hidden" asp-for="Id" />
}
<div class="mb-3">
    <label asp-for="Title" class="form-label"></label>
    <input asp-for="Title" class="form-control" />
    <span asp-validation-for="Title" class="text-danger small"></span>
</div>
<div class="mb-3">
    <label asp-for="Description" class="form-label"></label>
    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    <span asp-validation-for="Description" class="text-danger small"></span>
</div>
<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="City" class="form-label"></label>
        <input asp-for="City" class="form-control" />
        <span asp-validation-for="City" class="text-danger small"></span>
    </div>
    <div class="col-md-6 mb-3">
        <label asp-for="Address" class="form-label"></label>
        <input asp-for="Address" class="form-control" />
        <span asp-validation-for="Address" class="text-danger small"></span>
    </div>
</div>
<div class="row">
    <div class="col-md-3 mb-3">
        <label asp-for="PricePerNight" class="form-label"></label>
        <input asp-for="PricePerNight" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="PricePerNight" class="text-danger small"></span>
    </div>
    <div class="col-md-3 mb-3">
        <label asp-for="MaxGuests" class="form-label"></label>
        <input asp-for="MaxGuests" type="number" class="form-control" />
    </div>
    <div class="col-md-3 mb-3">
        <label asp-for="Bedrooms" class="form-label"></label>
        <input asp-for="Bedrooms" type="number" class="form-control" />
    </div>
    <div class="col-md-3 mb-3">
        <label asp-for="Bathrooms" class="form-label"></label>
        <input asp-for="Bathrooms" type="number" class="form-control" />
    </div>
</div>
<button type="submit" class="btn btn-primary text-white w-100"><i class="fa-solid fa-floppy-disk me-1"></i>Guardar</button>
